---
import { SITE_TITLE, NAV_LINKS } from '../consts';
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-bg/90 backdrop-blur-lg">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/" class="flex items-center gap-2 font-bold text-heading">
      <span class="text-xl">🐱</span>
      <span class="text-[17px] tracking-tight">{SITE_TITLE}</span>
    </a>
    <nav class="hidden items-center gap-5 text-[13px] md:flex">
      {NAV_LINKS.map((link) => (
        <a class="text-muted transition-colors hover:text-heading" href={link.href}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>
