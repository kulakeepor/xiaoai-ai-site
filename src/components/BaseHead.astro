---
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL } from '../consts';
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta Tags -->
<title>{Astro.props.title || SITE_TITLE}</title>
<meta name="title" content={Astro.props.title || SITE_TITLE} />
<meta name="description" content={Astro.props.description || SITE_DESCRIPTION} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={SITE_URL} />
<meta property="og:title" content={Astro.props.title || SITE_TITLE} />
<meta property="og:description" content={Astro.props.description || SITE_DESCRIPTION} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={SITE_URL} />
<meta property="twitter:title" content={Astro.props.title || SITE_TITLE} />
<meta property="twitter:description" content={Astro.props.description || SITE_DESCRIPTION} />

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
