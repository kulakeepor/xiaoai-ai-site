---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE, SECTIONS } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 8);

const postsBySection: Record<string, typeof allPosts> = {};
for (const post of allPosts) {
  const s = post.data.section || 'daily';
  if (!postsBySection[s]) postsBySection[s] = [];
  postsBySection[s].push(post);
}
---

<Layout>
  <!-- Hero -->
  <section class="hero-glow py-24 md:py-36">
    <div class="mx-auto max-w-5xl px-4 text-center">
      <p class="animate-fade-up mb-6 inline-block rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-xs font-medium text-primary">
        AI 学习站 · 每日更新 · 由小艾 🐱 驱动
      </p>
      <h1 class="animate-fade-up animate-delay-1 mx-auto max-w-3xl text-4xl font-bold leading-[1.15] tracking-tight text-heading md:text-6xl lg:text-7xl">
        从好奇到<span class="gradient-text">能做</span>
      </h1>
      <p class="animate-fade-up animate-delay-2 mx-auto mt-6 max-w-xl text-[15px] leading-relaxed text-muted md:text-base">
        AI 最新进展 · Vibe Coding 实战 · 软件工程入门<br/>
        一个让你真正学会用 AI 的学习站
      </p>
      <div class="animate-fade-up animate-delay-3 mt-10 flex flex-wrap items-center justify-center gap-3">
        <a class="rounded-lg bg-primary px-7 py-2.5 text-[13px] font-semibold text-white shadow-lg shadow-primary/20 transition-all hover:bg-primary-dark hover:shadow-primary/30" href="/daily">
          开始阅读
        </a>
        <a class="rounded-lg border border-border px-7 py-2.5 text-[13px] font-semibold text-heading transition-colors hover:border-primary hover:text-primary" href="/learn">
          知识学堂
        </a>
      </div>
    </div>
  </section>

  <!-- Section Cards -->
  <section class="border-y border-border/60 py-20">
    <div class="mx-auto max-w-5xl px-4">
      <h2 class="section-marker mb-2 text-lg font-bold text-heading md:text-xl">探索板块</h2>
      <p class="mb-10 text-[13px] text-muted">选择你感兴趣的方向。</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {Object.entries(SECTIONS).map(([key, section]) => (
          <a href={`/${key}`} class="card-glow group rounded-xl border border-border bg-surface p-5 transition-colors hover:border-primary/40">
            <div class="mb-3 text-2xl">{section.icon}</div>
            <h3 class="mb-1.5 text-[13px] font-semibold text-heading">
              {section.title}
              <span class="ml-1 text-primary opacity-0 transition-opacity group-hover:opacity-100">→</span>
            </h3>
            <p class="text-[13px] leading-relaxed text-muted">{section.description}</p>
            <span class="mt-2 inline-block text-xs text-primary/70">
              {(postsBySection[key] || []).length} 篇
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-4">
      <h2 class="section-marker mb-2 text-lg font-bold text-heading md:text-xl">最新内容</h2>
      <p class="mb-10 text-[13px] text-muted">最近更新的文章。</p>
      <div class="space-y-3">
        {recentPosts.map((post) => {
          const section = SECTIONS[post.data.section];
          return (
            <a href={`/blog/${post.id}`} class="card-glow group block rounded-xl border border-border bg-surface p-5 transition-colors hover:border-primary/40">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[11px] font-medium text-primary rounded-full bg-primary/5 border border-primary/15 px-2.5 py-0.5">
                  {section?.icon} {section?.title}
                </span>
                {post.data.difficulty && (
                  <span class="text-[11px] text-muted rounded-full bg-surface-dim px-2 py-0.5">
                    {post.data.difficulty}
                  </span>
                )}
              </div>
              <h3 class="text-[15px] font-semibold text-heading group-hover:text-primary transition-colors">{post.data.title}</h3>
              <p class="mt-1 text-[13px] text-muted line-clamp-2">{post.data.description}</p>
              <div class="mt-2 flex items-center gap-3 text-[12px] text-muted">
                <FormattedDate date={post.data.pubDate} />
                {post.data.tags?.slice(0, 3).map((tag) => (
                  <span class="text-primary/60">#{tag}</span>
                ))}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="hero-glow border-y border-border/60 py-24">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="mb-4 text-2xl font-bold text-heading md:text-4xl">开始你的 AI 学习之旅</h2>
      <p class="mb-8 text-[13px] text-muted md:text-[15px]">
        每天精选最重要的 AI 进展，附人话解读。从零基础到实战，跟着走就行。
      </p>
      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a class="rounded-lg bg-primary px-8 py-2.5 text-[13px] font-semibold text-white shadow-lg shadow-primary/20 transition-all hover:bg-primary-dark" href="/daily">
          阅读今日 AI 日报
        </a>
        <a class="rounded-lg border border-border px-8 py-2.5 text-[13px] font-semibold text-heading transition-colors hover:border-primary hover:text-primary" href="/learn">
          从零开始学
        </a>
      </div>
    </div>
  </section>
</Layout>
