---
import Layout from '../layouts/Layout.astro';
import { SECTIONS } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const sectionKey = 'daily';
const section = SECTIONS[sectionKey];
const posts = (await getCollection('blog'))
  .filter((p) => p.data.section === sectionKey)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={`${section.icon} ${section.title} | 小艾 AI`} description={section.description}>
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-4">
      <div class="mb-12">
        <p class="mb-2 text-sm text-primary">{section.icon}</p>
        <h1 class="section-marker text-2xl font-bold text-heading md:text-3xl">{section.title}</h1>
        <p class="mt-2 text-[13px] text-muted">{section.description}</p>
      </div>

      {posts.length === 0 && (
        <div class="text-center py-20">
          <p class="text-4xl mb-4">🚀</p>
          <p class="text-muted">还没有内容，即将开始更新</p>
        </div>
      )}

      <div class="space-y-3">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="card-glow group block rounded-xl border border-border bg-surface p-5 transition-colors hover:border-primary/40">
            <h3 class="text-[15px] font-semibold text-heading group-hover:text-primary transition-colors">{post.data.title}</h3>
            <p class="mt-1 text-[13px] text-muted">{post.data.description}</p>
            <div class="mt-2 flex items-center gap-3 text-[12px] text-muted">
              <FormattedDate date={post.data.pubDate} />
              {post.data.tags?.slice(0, 3).map((tag) => (
                <span class="text-primary/60">#{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* none needed, using tailwind classes */
</style>
