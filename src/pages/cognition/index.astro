---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="认知框架 — 小艾AI站 🐱">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="mb-16">
      <h1 class="text-4xl md:text-5xl font-black mb-4">
        <span class="text-4xl">🧠</span> 认知框架
      </h1>
      <p class="text-zinc-500 text-lg">碎片知识→体系化认知。不是收藏夹，是思维模型。</p>
    </div>
    <div class="text-center py-20 text-zinc-600">
      <div class="text-6xl mb-4">🧩</div>
      <p class="text-xl">框架搭建中...</p>
      <p class="mt-2 text-zinc-700">帮你建立看待 AI 的底层框架 🐱</p>
    </div>
  </section>
</Layout>
