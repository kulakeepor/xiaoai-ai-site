---
import Layout from '../layouts/Layout.astro';
import { SECTIONS } from '../consts';
import { LEARN_TREE } from '../data/learn-tree';

const sectionKey = 'learn';
const section = SECTIONS[sectionKey];
---

<Layout title={`${section.icon} ${section.title} | 小艾 AI`} description={section.description}>
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      
      <!-- Header -->
      <div class="mb-10 text-center">
        <p class="text-4xl mb-3">{section.icon}</p>
        <h1 class="text-2xl font-bold text-heading md:text-3xl">{section.title}</h1>
        <p class="mt-2 text-[14px] text-muted max-w-md mx-auto">{section.description}</p>
      </div>

      <!-- 学习路径卡片 -->
      <div class="space-y-6">
        {LEARN_TREE.map((week) => {
          const doneCount = week.days.filter(d => d.status === 'done').length;
          const totalCount = week.days.length;
          const pct = Math.round((doneCount / totalCount) * 100);
          
          return (
            <div class="week-card rounded-2xl border border-border bg-surface overflow-hidden">
              <!-- Week Header -->
              <div class="px-6 py-4 bg-surface-dim border-b border-border flex items-center justify-between">
                <div>
                  <h2 class="text-[15px] font-semibold text-heading">{week.title}</h2>
                  <p class="text-[12px] text-muted mt-0.5">{totalCount} 个学习单元</p>
                </div>
                <div class="text-right">
                  <span class="text-[13px] font-medium text-primary">{pct}%</span>
                  <div class="w-20 bg-border rounded-full h-1.5 mt-1">
                    <div class="bg-primary h-1.5 rounded-full" style={`width: ${pct}%`}></div>
                  </div>
                </div>
              </div>

              <!-- Days Grid -->
              <div class="p-4 grid grid-cols-1 sm:grid-cols-2 gap-2">
                {week.days.map((day) => (
                  <a
                    href={day.slug || '#'}
                    class:list={[
                      'flex items-center gap-3 px-4 py-3 rounded-xl border transition-all text-[13px]',
                      day.status === 'done'
                        ? 'border-green-200 bg-green-50 text-green-700 hover:border-green-300'
                        : day.status === 'current'
                        ? 'border-primary/30 bg-primary/5 text-primary hover:border-primary/50'
                        : day.status === 'locked'
                        ? 'border-border bg-surface text-muted/40 cursor-not-allowed'
                        : 'border-border bg-bg text-muted hover:border-primary/30 hover:text-heading'
                    ]}
                  >
                    <span class="text-lg leading-none shrink-0">
                      {day.status === 'done' ? '✅' : day.status === 'current' ? '🔄' : day.status === 'locked' ? '🔒' : '○'}
                    </span>
                    <span class="leading-snug">{day.title}</span>
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>

      <!-- 当前状态 -->
      <div class="mt-8 text-center text-[13px] text-muted">
        <p>共 30 个学习单元 · 从 Day 8 机器学习核心概念开始</p>
        <p class="mt-1 text-primary/70">🔄 当前进度：Day 8 · 机器学习全景图</p>
      </div>

    </div>
  </section>
</Layout>
