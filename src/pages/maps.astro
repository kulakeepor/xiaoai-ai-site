---
import Layout from '../layouts/Layout.astro';
import { SECTIONS } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const sectionKey = 'maps';
const section = SECTIONS[sectionKey];
const posts = (await getCollection('blog'))
  .filter((p) => p.data.section === sectionKey)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={`${section.icon} ${section.title} | 小艾 AI`} description={section.description}>
  <section class="section-header">
    <span class="icon">{section.icon}</span>
    <h1>{section.title}</h1>
    <p>{section.description}</p>
  </section>

  <div class="post-list">
    {posts.length === 0 && <p class="empty">还没有内容，即将开始更新 🚀</p>}
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="post-card">
        <h3>{post.data.title}</h3>
        <p class="post-desc">{post.data.description}</p>
        <div class="post-meta">
          <FormattedDate date={post.data.pubDate} />
          {post.data.tags?.slice(0, 3).map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .section-header {
    text-align: center;
    padding: 2rem 0 3rem;
  }
  .icon { font-size: 3rem; }
  .section-header h1 { margin: 0.5rem 0 0.25rem; }
  .section-header p { color: #666; }
  .post-list { display: flex; flex-direction: column; gap: 1rem; }
  .post-card {
    display: block;
    padding: 1.25rem;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }
  .post-card:hover {
    border-color: #7c3aed;
    box-shadow: 0 2px 8px rgba(124,58,237,0.08);
  }
  .post-card h3 { margin: 0 0 0.25rem; }
  .post-desc { color: #666; font-size: 0.9rem; margin: 0.25rem 0; }
  .post-meta { font-size: 0.8rem; color: #999; display: flex; gap: 0.5rem; align-items: center; }
  .tag { color: #7c3aed; background: #f8f5ff; padding: 1px 6px; border-radius: 3px; font-size: 0.75rem; }
  .empty { text-align: center; color: #888; padding: 3rem 0; }
</style>
