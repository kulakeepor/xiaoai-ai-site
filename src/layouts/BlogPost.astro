---
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, AUTHOR } from '../consts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  section?: string;
  tags?: string[];
  difficulty?: string;
}

const { title, description, pubDate, updatedDate, heroImage, section, tags = [], difficulty } = Astro.props;
---

<Layout title={`${title} | ${SITE_TITLE}`} description={description}>
  <article>
    {heroImage && (
      <div class="hero-image">
        <img width={1020} height={510} src={heroImage} alt={title} />
      </div>
    )}
    <div class="prose">
      <div class="post-meta">
        <span class="section-badge">{section}</span>
        {difficulty && <span class="difficulty-badge">{difficulty}</span>}
      </div>
      <h1>{title}</h1>
      <div class="post-info">
        <span class="author">{AUTHOR} 🐱</span>
        ·
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <>
            · 更新于 <FormattedDate date={updatedDate} />
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
      <hr />
      <slot />
    </div>
  </article>
</Layout>

<style>
  .hero-image {
    margin-bottom: 2rem;
    border-radius: 12px;
    overflow: hidden;
  }
  .hero-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }
  .post-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .section-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    background: #f0e6ff;
    color: #7c3aed;
  }
  .difficulty-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    background: #e6f7ff;
    color: #0284c7;
  }
  .post-info {
    color: #666;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .tag {
    font-size: 0.8rem;
    color: #7c3aed;
    background: #f8f5ff;
    padding: 2px 8px;
    border-radius: 4px;
  }
</style>
