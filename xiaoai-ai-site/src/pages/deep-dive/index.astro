---
import Layout from '../../layouts/Layout.astro';
import { fetchRecords, TABLES, getText, getUrl, getTags, getDate, getNumber } from '../../lib/feishu';

const records = await fetchRecords(TABLES.deepDive);
const sorted = records.sort((a, b) => (b.fields['发布日期'] || 0) - (a.fields['发布日期'] || 0));
---

<Layout title="深度拆解 — 小艾AI站 🐱">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="mb-16">
      <h1 class="text-4xl md:text-5xl font-black mb-4">
        <span class="text-4xl">🔬</span> 深度拆解
      </h1>
      <p class="text-zinc-500 text-lg">重磅论文、革命性产品——掰开了揉碎了给你讲明白。</p>
    </div>

    {sorted.length === 0 && (
      <div class="text-center py-20 text-zinc-600">
        <div class="text-6xl mb-4">🔬</div>
        <p class="text-xl">深度内容准备中...</p>
      </div>
    )}

    <div class="grid gap-6">
      {sorted.map((rec) => {
        const f = rec.fields;
        const title = getText(f['标题']);
        const date = getDate(f['发布日期']);
        const tags = getTags(f['标签']);
        const summary = getText(f['摘要']);
        const keyPoints = getText(f['核心要点']);
        const category = getText(f['类别']);
        const difficulty = getText(f['学习难度']);
        const value = getNumber(f['实用价值']);
        const theme = getText(f['主题']);
        const link = getUrl(f['链接']);

        return (
          <div class="group block p-6 rounded-xl border border-zinc-800/50 bg-zinc-900/30 hover:border-amber-500/30 hover:bg-zinc-900/60 transition-all">
            <div class="flex flex-wrap items-center gap-3 mb-3 text-sm text-zinc-500">
              {date && <span>{date}</span>}
              {category && <span class="px-2 py-0.5 rounded-full bg-amber-500/10 text-amber-400 text-xs">{category}</span>}
              {difficulty && <span class="px-2 py-0.5 rounded-full bg-zinc-800 text-zinc-400 text-xs">{difficulty}</span>}
              {value > 0 && <span class="text-amber-400">实用价值: {value}/5</span>}
              {tags.map((tag: string) => (
                <span class="px-2 py-0.5 rounded-full bg-zinc-800 text-zinc-400 text-xs">{tag}</span>
              ))}
            </div>
            <h2 class="text-xl font-bold group-hover:text-amber-400 transition-colors">{title}</h2>
            {theme && <p class="text-zinc-500 text-sm mt-1">主题：{theme}</p>}
            {summary && <p class="text-zinc-400 mt-2 leading-relaxed">{summary}</p>}
            {keyPoints && (
              <p class="text-zinc-500 mt-3 text-sm border-l-2 border-amber-500/30 pl-3 whitespace-pre-line">{keyPoints}</p>
            )}
            {link && (
              <a href={link} target="_blank" class="inline-flex items-center gap-1 mt-3 text-sm text-amber-500/70 hover:text-amber-400">
                查看原文 ↗
              </a>
            )}
          </div>
        );
      })}
    </div>
  </section>
</Layout>
