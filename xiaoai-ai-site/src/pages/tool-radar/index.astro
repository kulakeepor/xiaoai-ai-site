---
import Layout from '../../layouts/Layout.astro';
import { fetchRecords, TABLES, getText, getUrl, getTags, getDate, getNumber } from '../../lib/feishu';

const records = await fetchRecords(TABLES.toolRadar);
const sorted = records.sort((a, b) => (b.fields['发现日期'] || 0) - (a.fields['发现日期'] || 0));
---

<Layout title="工具雷达 — 小艾AI站 🐱">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="mb-16">
      <h1 class="text-4xl md:text-5xl font-black mb-4">
        <span class="text-4xl">🛠️</span> 工具雷达
      </h1>
      <p class="text-zinc-500 text-lg">好用的 AI 工具、开源项目、生产力神器。发现即分享。</p>
    </div>

    {sorted.length === 0 && (
      <div class="text-center py-20 text-zinc-600">
        <div class="text-6xl mb-4">📡</div>
        <p class="text-xl">雷达扫描中...</p>
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {sorted.map((rec) => {
        const f = rec.fields;
        const title = getText(f['标题']);
        const product = getText(f['产品名称']);
        const date = getDate(f['发现日期']);
        const tags = getTags(f['标签']);
        const coreFunc = getText(f['核心功能']);
        const problem = getText(f['解决什么问题']);
        const learnings = getText(f['可借鉴点']);
        const model = getText(f['商业模式']);
        const rating = getNumber(f['推荐指数']);
        const link = getUrl(f['链接']);

        return (
          <div class="group block p-6 rounded-xl border border-zinc-800/50 bg-zinc-900/30 hover:border-amber-500/30 hover:bg-zinc-900/60 transition-all">
            <div class="flex flex-wrap items-center gap-3 mb-3 text-sm text-zinc-500">
              {date && <span>{date}</span>}
              {model && <span class="px-2 py-0.5 rounded-full bg-amber-500/10 text-amber-400 text-xs">{model}</span>}
              {rating > 0 && (
                <span class="text-amber-400">{'★'.repeat(Math.min(rating, 5))}{'☆'.repeat(Math.max(0, 5 - rating))}</span>
              )}
              {tags.map((tag: string) => (
                <span class="px-2 py-0.5 rounded-full bg-zinc-800 text-zinc-400 text-xs">{tag}</span>
              ))}
            </div>
            <h2 class="text-xl font-bold group-hover:text-amber-400 transition-colors">{title}</h2>
            {product && product !== title && <p class="text-zinc-500 text-sm mt-1">产品：{product}</p>}
            {problem && <p class="text-zinc-400 mt-2">{problem}</p>}
            {coreFunc && <p class="text-zinc-500 mt-2 text-sm">核心功能：{coreFunc}</p>}
            {learnings && (
              <p class="text-zinc-500 mt-3 text-sm border-l-2 border-amber-500/30 pl-3">💡 {learnings}</p>
            )}
            {link && (
              <a href={link} target="_blank" class="inline-flex items-center gap-1 mt-3 text-sm text-amber-500/70 hover:text-amber-400">
                访问 ↗
              </a>
            )}
          </div>
        );
      })}
    </div>
  </section>
</Layout>
